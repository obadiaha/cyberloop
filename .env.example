# ============================================================
# CyberLoop — Environment Variables
# ============================================================
# Copy this file: cp .env.example .env
# Then fill in your values.
# ============================================================

# Gemini API Key (required)
# Get one at: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud Project ID
# Used for Firestore, Cloud Storage, and Cloud Run deployment
GOOGLE_CLOUD_PROJECT=cyberloop-hackathon

# Cloud Storage bucket for question trees & rubrics
# Created automatically by deploy.sh
GCS_BUCKET_NAME=cyberloop-hackathon-data

# Firestore database ID
# Use "(default)" unless you created a named database
FIRESTORE_DATABASE=(default)

# ============================================================
# Local Development Overrides (optional)
# ============================================================

# Backend port (default: 8080)
# PORT=8080

# Frontend API URL (set automatically in production)
# For local dev, this points to the local backend
# VITE_API_URL=http://localhost:8080

# Log level (debug, info, warning, error)
# LOG_LEVEL=info
