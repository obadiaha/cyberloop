rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // CyberLoop Firestore Security Rules
    // ============================================================
    // HACKATHON MODE: Open read/write for development speed.
    // TODO: Lock down for production with Firebase Auth.
    // ============================================================

    // Sessions collection
    match /sessions/{sessionId} {
      // Allow creating and reading sessions
      allow read, write: if true;

      // Exchanges subcollection (interview Q&A pairs)
      match /exchanges/{exchangeId} {
        allow read, write: if true;
      }

      // Report card subcollection
      match /report_card/{reportId} {
        allow read, write: if true;
      }
    }

    // ============================================================
    // PRODUCTION RULES (uncomment when adding Firebase Auth)
    // ============================================================
    //
    // match /sessions/{sessionId} {
    //   // Only the session creator can read/write
    //   allow create: if request.auth != null;
    //   allow read, update: if request.auth != null
    //     && resource.data.user_id == request.auth.uid;
    //   allow delete: if false; // Never delete interview data
    //
    //   match /exchanges/{exchangeId} {
    //     allow read: if request.auth != null
    //       && get(/databases/$(database)/documents/sessions/$(sessionId)).data.user_id == request.auth.uid;
    //     allow write: if false; // Only backend writes exchanges
    //   }
    //
    //   match /report_card/{reportId} {
    //     allow read: if request.auth != null
    //       && get(/databases/$(database)/documents/sessions/$(sessionId)).data.user_id == request.auth.uid;
    //     allow write: if false; // Only backend writes reports
    //   }
    // }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
